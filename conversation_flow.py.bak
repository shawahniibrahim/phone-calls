# Flow for asking questions
INQUIRY_FLOW = {
    "name": "Ask Questions",
    "phone_number": None,
    "timeout": 300,
    "steps": [
        {
            "step": 1,
            "expect": "greeting or asking how they can help",
            "respond_with": "Ask about services",
            "example": "What services do you offer?",
            "assertions": [
                {"type": "contains", "value": "services", "description": "Asked about services"}
            ]
        },
        {
            "step": 2,
            "expect": "explaining services",
            "respond_with": "Ask about insurance",
            "example": "Do you accept Blue Cross insurance?",
            "assertions": [
                {"type": "contains", "value": "insurance", "description": "Asked about insurance"}
            ]
        },
        {
            "step": 3,
            "expect": "insurance information",
            "respond_with": "Ask about hours",
            "example": "What are your office hours?",
            "assertions": [
                {"type": "contains", "value": "hours", "description": "Asked about hours"}
            ]
        },
        {
            "step": 4,
            "expect": "providing hours",
            "respond_with": "Thank them",
            "example": "Thank you for the information",
            "assertions": []
        },
        {
            "step": 5,
            "expect": "Saying goodbye",
            "respond_with": "Say goodbye and hang up",
            "example": "Goodbye",
            "action": "hangup",
            "assertions": [
                {"type": "step_reached", "description": "Call completed"}
            ]
        },
    ]
}

